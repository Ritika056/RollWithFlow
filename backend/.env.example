APP_ENV=local
DATABASE_URL=sqlite:///./rollwithflow.db
# Production example: postgresql+psycopg://rollwithflow:password@host:5432/rollwithflow
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SECRET_KEY=replace-with-a-long-random-production-secret-at-least-32-characters
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=choose-a-strong-private-password
ADMIN_DISPLAY_NAME=RollWithFlow Admin
# Optional Phase 6A provider credentials. Keep real values server-side only.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8001/api/providers/spotify/callback
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
# Optional local media storage overrides for browser audio imports.
MEDIA_ROOT=./media
AUDIO_UPLOAD_DIR=./media/audio
FFMPEG_PATH=
DISCOVERY_DEFAULT_LIMIT=50
DISCOVERY_MAX_LIMIT=100
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
