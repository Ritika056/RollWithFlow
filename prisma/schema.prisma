generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  playlists Playlist[]
}

model Playlist {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
}